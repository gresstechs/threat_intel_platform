/*
 * Jenkinsfile — Automated Threat Intelligence Correlation Platform
 * Deliverable D3.2 | MSc Applied Computing Dissertation 2024/25
 * Student: Chidera Progress Nwaokwa (240054490)
 *
 * Security: .env is written at runtime from Jenkins credentials store.
 * No static credentials file is stored on the server.
 *
 * Pipeline Stages:
 *   1. Environment Validation   — write .env, verify credentials, DB connectivity
 *   2. Unit Tests               — run full pytest suite with coverage
 *   3. API Ingestion            — fetch latest indicators from all 3 feeds
 *   4. Alert Prioritisation     — score and queue new indicators
 *   5. Model Performance Check  — evaluate current model on latest data
 *   6. Model Retraining         — retrain if accuracy drops below threshold
 *   7. Dashboard Refresh        — signal Grafana to reload data
 *   8. Notification             — report pipeline results
 *
 * Triggers:
 *   - Scheduled: Every 6 hours (API ingestion + prioritisation)
 *   - Weekly:    Full retraining evaluation (Sundays 02:00)
 *   - On commit: Unit tests + environment validation only
 */

pipeline {

    agent any

    // ── Environment Variables ────────────────────────────────────────────────
    environment {
        PYTHON           = '/usr/bin/python3'
        SRC_DIR          = 'src'
        TEST_DIR         = 'tests'
        MODEL_DIR        = 'models'
        REPORTS_DIR      = 'reports'
        COVERAGE_MIN     = '60'
        ACCURACY_MIN     = '0.95'
        RETRAIN_MAX_DAYS = '7'
        PLATFORM_EMAIL   = 'bi78xz@student.sunderland.ac.uk'

        // DB connection details (non-secret parts)
        DB_HOST = 'ep-gentle-water-ablbxqvw-pooler.eu-west-2.aws.neon.tech'
        DB_PORT = '5432'
        DB_NAME = 'threat_intel_platform'
        DB_USER = 'neondb_owner'
    }

    // ── Pipeline Options ─────────────────────────────────────────────────────
    options {
        timeout(time: 2, unit: 'HOURS')
        buildDiscarder(logRotator(numToKeepStr: '30'))
        disableConcurrentBuilds()
        timestamps()
    }

    // ── Triggers ─────────────────────────────────────────────────────────────
    triggers {
        // Every 6 hours for ingestion + Sunday 02:00 for weekly retraining
        cron('0 */6 * * *\n0 2 * * 0')
    }

    // ── Parameters ───────────────────────────────────────────────────────────
    parameters {
        booleanParam(
            name: 'FORCE_RETRAIN',
            defaultValue: false,
            description: 'Force model retraining regardless of current accuracy'
        )
        booleanParam(
            name: 'SKIP_INGESTION',
            defaultValue: false,
            description: 'Skip API ingestion (run tests and evaluation only)'
        )
        choice(
            name: 'LOG_LEVEL',
            choices: ['INFO', 'DEBUG', 'WARNING'],
            description: 'Platform logging level'
        )
    }

    // ════════════════════════════════════════════════════════════════════════
    // STAGES
    // ════════════════════════════════════════════════════════════════════════
    stages {

        // ── Stage 1: Environment Validation ──────────────────────────────────
        stage('Environment Validation') {
            steps {
                echo '━━━ Stage 1: Environment Validation ━━━'

                // Write .env at runtime from Jenkins credentials store
                // No static .env file needed on the server
                withCredentials([
                    string(credentialsId: 'otx-api-key',       variable: 'OTX_KEY'),
                    string(credentialsId: 'virustotal-api-key', variable: 'VT_KEY'),
                    string(credentialsId: 'abuseipdb-api-key',  variable: 'ABUSE_KEY'),
                    string(credentialsId: 'neon-db-url',        variable: 'DB_PASSWORD'),
                ]) {
                    sh '''
                        # Write .env from Jenkins credentials — recreated on every build
                        cat > .env << ENVEOF
OTX_API_KEY=${OTX_KEY}
VT_API_KEY=${VT_KEY}
ABUSEIPDB_API_KEY=${ABUSE_KEY}
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_SSLMODE=require
LOG_LEVEL=${LOG_LEVEL}
RATE_LIMIT_SLEEP=1.0
MAX_RETRIES=3
RETRY_BACKOFF=2.0
CACHE_TTL=3600
PROCESSING_TIMEOUT=5.0
ENVEOF
                        echo "✅ .env written from Jenkins credentials store"
                    '''
                }

                script {
                    // Install dependencies
                    sh """
                        /usr/bin/python3 -m pip install -r requirements.txt \
                            --break-system-packages --quiet
                        echo "✅ Dependencies installed"
                    """

                    // Validate credentials and DB connection
                    sh """
                        ${PYTHON} -c "
import sys
sys.path.insert(0, '${SRC_DIR}')
from config import Config
Config.validate()
print('✅ API credentials validated')
"
                    """

                    // Validate DB connectivity
                    sh """
                        ${PYTHON} -c "
import sys
sys.path.insert(0, '${SRC_DIR}')
from db import db
db.connect(min_conn=1, max_conn=2)
stats = db.get_stats()
total = stats['total_indicators']
print('✅ Database connected — ' + str(total) + ' indicators stored')
db.close()
"
                    """

                    // Create output directories
                    sh "mkdir -p ${REPORTS_DIR} ${MODEL_DIR}"

                    echo "✅ Environment validation passed"
                }
            }
            post {
                failure {
                    echo "❌ Environment validation failed — check credentials and DB"
                    error("Cannot proceed without valid environment")
                }
            }
        }

        // ── Stage 2: Unit Tests ───────────────────────────────────────────────
        stage('Unit Tests') {
            steps {
                echo '━━━ Stage 2: Unit Tests ━━━'
                script {
                    sh """
                        ${PYTHON} -m pytest ${TEST_DIR}/ \
                            -v \
                            --tb=short \
                            --junit-xml=${REPORTS_DIR}/test_results.xml \
                            2>&1 | tee ${REPORTS_DIR}/test_output.txt
                    """
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${REPORTS_DIR}/test_results.xml"
                }
                failure {
                    echo "❌ Unit tests failed — pipeline aborted"
                    error("Tests must pass before proceeding")
                }
                success {
                    echo "✅ All unit tests passed"
                }
            }
        }

        // ── Stage 3: API Ingestion ────────────────────────────────────────────
        stage('API Ingestion') {
            when {
                not { expression { return params.SKIP_INGESTION } }
            }
            steps {
                echo '━━━ Stage 3: API Ingestion ━━━'
                script {
                    sh """
                        ${PYTHON} ${SRC_DIR}/pipeline_runner.py \
                            --stage ingest \
                            --log-level ${params.LOG_LEVEL} \
                            2>&1 | tee ${REPORTS_DIR}/ingestion_output.txt
                    """
                    archiveArtifacts artifacts: "${REPORTS_DIR}/ingestion_output.txt",
                                     allowEmptyArchive: true
                }
            }
            post {
                success { echo "✅ API ingestion complete" }
                failure { echo "⚠️ Ingestion failed — continuing with existing data" }
            }
        }

        // ── Stage 4: Alert Prioritisation ─────────────────────────────────────
        stage('Alert Prioritisation') {
            when {
                not { expression { return params.SKIP_INGESTION } }
            }
            steps {
                echo '━━━ Stage 4: Alert Prioritisation ━━━'
                script {
                    sh """
                        ${PYTHON} ${SRC_DIR}/pipeline_runner.py \
                            --stage prioritise \
                            --log-level ${params.LOG_LEVEL} \
                            2>&1 | tee ${REPORTS_DIR}/prioritisation_output.txt
                    """

                    def output = readFile("${REPORTS_DIR}/prioritisation_output.txt")
                    def reduction = "0.0"
                    output.eachLine { line ->
                        if (line.contains("Workload reduction:")) {
                            reduction = line.replaceAll(".*Workload reduction: ([\\d.]+)%.*", "\$1")
                        }
                    }
                    env.WORKLOAD_REDUCTION = reduction
                    echo "📊 Workload reduction: ${reduction}%"
                    if (reduction.toFloat() >= 40.0) {
                        echo "✅ Objective 3 target met: ${reduction}% >= 40%"
                    } else {
                        echo "⚠️ Objective 3: ${reduction}% < 40% target"
                    }
                }
            }
        }

        // ── Stage 5: Model Performance Check ─────────────────────────────────
        stage('Model Performance Check') {
            steps {
                echo '━━━ Stage 5: Model Performance Check ━━━'
                script {
                    sh """
                        ${PYTHON} ${SRC_DIR}/pipeline_runner.py \
                            --stage evaluate \
                            --accuracy-threshold ${ACCURACY_MIN} \
                            2>&1 | tee ${REPORTS_DIR}/evaluation_output.txt
                    """

                    def output = readFile("${REPORTS_DIR}/evaluation_output.txt")
                    def currentAccuracy = "0.0"
                    def daysSince = "0"
                    def needsRetrain = false

                    output.eachLine { line ->
                        if (line.contains("Current accuracy:")) {
                            currentAccuracy = line.replaceAll(".*Current accuracy: ([\\d.]+).*", "\$1")
                        }
                        if (line.contains("Days since last retrain:")) {
                            daysSince = line.replaceAll(".*Days since last retrain: (\\d+).*", "\$1")
                        }
                        if (line.contains("Needs retrain: True")) {
                            needsRetrain = true
                        }
                    }

                    env.CURRENT_ACCURACY   = currentAccuracy
                    env.DAYS_SINCE_RETRAIN = daysSince
                    env.NEEDS_RETRAIN      = needsRetrain ? "true" : "false"

                    echo "📊 Current model accuracy: ${currentAccuracy}"
                    echo "📊 Days since last retrain: ${daysSince}"
                    echo "🔄 Retraining needed: ${needsRetrain}"
                }
            }
        }

        // ── Stage 6: Model Retraining ─────────────────────────────────────────
        stage('Model Retraining') {
            when {
                anyOf {
                    expression { return params.FORCE_RETRAIN }
                    expression { return env.NEEDS_RETRAIN == "true" }
                }
            }
            steps {
                echo '━━━ Stage 6: Model Retraining ━━━'
                script {
                    sh """
                        ${PYTHON} ${SRC_DIR}/pipeline_runner.py \
                            --stage retrain \
                            --accuracy-threshold ${ACCURACY_MIN} \
                            2>&1 | tee ${REPORTS_DIR}/retraining_output.txt
                    """

                    def output = readFile("${REPORTS_DIR}/retraining_output.txt")
                    def newAccuracy = "0.0"
                    output.eachLine { line ->
                        if (line.contains("New model accuracy:")) {
                            newAccuracy = line.replaceAll(".*New model accuracy: ([\\d.]+).*", "\$1")
                        }
                    }
                    env.NEW_ACCURACY = newAccuracy
                    echo "📊 New model accuracy: ${newAccuracy}"

                    if (newAccuracy.toFloat() >= ACCURACY_MIN.toFloat()) {
                        echo "✅ Retraining successful — new model deployed"
                    } else {
                        echo "⚠️ Insufficient live data for retraining — baseline model retained"
                    }

                    archiveArtifacts artifacts: "${MODEL_DIR}/*.pkl",
                                     fingerprint: true,
                                     allowEmptyArchive: true
                }
            }
            post {
                success { echo "✅ Model retrained and deployed" }
                failure { echo "⚠️ Retraining skipped — not enough live data yet" }
            }
        }

        // ── Stage 7: Dashboard Refresh ────────────────────────────────────────
        stage('Dashboard Refresh') {
            steps {
                echo '━━━ Stage 7: Dashboard Refresh ━━━'
                script {
                    sh """
                        ${PYTHON} ${SRC_DIR}/pipeline_runner.py \
                            --stage dashboard-refresh \
                            2>&1 | tee ${REPORTS_DIR}/dashboard_output.txt
                    """
                    echo "✅ Dashboard refresh complete"
                }
            }
            post {
                failure { echo "⚠️ Dashboard refresh failed — data still updated in DB" }
            }
        }

    } // end stages

    // ════════════════════════════════════════════════════════════════════════
    // POST-PIPELINE ACTIONS
    // ════════════════════════════════════════════════════════════════════════
    post {

        success {
            echo """
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
✅ PIPELINE COMPLETED SUCCESSFULLY
Build:             #${env.BUILD_NUMBER}
Duration:          ${currentBuild.durationString}
Model Accuracy:    ${env.CURRENT_ACCURACY ?: 'Not evaluated'}
Workload Reduction:${env.WORKLOAD_REDUCTION ?: 'Not measured'}%
Retrained:         ${env.NEEDS_RETRAIN == 'true' ? 'Yes' : 'No'}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
"""
        }

        failure {
            echo "❌ PIPELINE FAILED — Build #${env.BUILD_NUMBER}"
        }

        always {
            // Archive all reports
            archiveArtifacts artifacts: "${REPORTS_DIR}/**/*",
                             allowEmptyArchive: true
            // Clean up .env after pipeline completes — no credentials left on disk
            sh 'rm -f .env'
        }
    }

} // end pipeline